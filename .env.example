# Root deployment environment
# Copy this file to .env and fill in values.

# Required for deployment
PRIVATE_KEY=

# Required only for Sepolia deployment
SEPOLIA_RPC_URL=

# Optional: use an existing ERC20 instead of deploying StakeToken
STAKING_TOKEN=

# Optional: override ERC1155 base metadata URI
BADGE_URI=https://api.openstake.xyz/badges/{id}.json
