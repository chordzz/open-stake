# Compiler files
cache/
out/

# Commonly ignored directories
.logs/
.ignore/

# Ignores development broadcast logs
!/broadcast
/broadcast/*/31337/
/broadcast/**/dry-run/

# Docs
docs/

# Dotenv file
.env
.env.*
!.env.example

# Local secret env files (any package/module)
**/.env.local
**/.env.*.local

# Sensitive keys/certificates/keystores
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
id_rsa
id_ed25519

# Secret backups and wallet artifacts
*.kdbx
*.mnemonic
mnemonic.txt
seed.txt
private_key.txt
wallet.json
